# VizardFree Backend Environment Variables
# Copy this to .env and fill in values

# Database (SQLite default – switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:////data/vizardfree.db
# DATABASE_URL=postgresql+asyncpg://vizard:secret@localhost:5432/vizardfree

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage paths
UPLOAD_DIR=/data/uploads
OUTPUT_DIR=/data/outputs
MODELS_DIR=/data/models

# Whisper transcription model
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# CORS – comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Max upload size (bytes)
MAX_UPLOAD_SIZE=2147483648

# Debug mode
DEBUG=false
